# Nairi Docker Environment Variables
# Copy to .env and adjust for your environment

# API Tokens — JSON object mapping token names to scope arrays
# Default dev token grants full access (posts + taxonomy + admin scopes)
NAIRI_API_TOKENS={"admin-token":["posts:read","posts:write","posts:publish","taxonomy:read","taxonomy:write","admin:all"]}

# Optional: Cloudflare invalidation (for public site cache purging)
# NAIRI_PUBLIC_INVALIDATION_DISPATCHER=none
# NAIRI_PUBLIC_INVALIDATION_CLOUDFLARE_ZONE_ID=
# NAIRI_PUBLIC_INVALIDATION_CLOUDFLARE_API_TOKEN=
