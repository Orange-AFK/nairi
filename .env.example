# Nairi example environment. Placeholder values only.
NAIRI_SERVICE_NAME=nairi-api
NAIRI_VERSION=0.1.0
NAIRI_API_TOKENS={"local-admin":["admin:all"]}
NAIRI_DATABASE_PATH=./data/nairi.sqlite3
NAIRI_PUBLIC_INVALIDATION_DISPATCHER=none
# Optional Cloudflare adapter placeholders. Leave unset unless the Cloudflare dispatcher is being configured.
# NAIRI_PUBLIC_INVALIDATION_CLOUDFLARE_ZONE_ID=example-zone-id
# NAIRI_PUBLIC_INVALIDATION_CLOUDFLARE_API_TOKEN=example-cloudflare-token
